<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Login | NotesManager</title>
    <!-- Preconnect for faster external resource loading (if any) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Google Fonts: Inter for modern, clean typography -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
        rel="stylesheet">
    <!-- Font Awesome 6 (free icons) - adds subtle iconography for better UX -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Main custom CSS (separate file, MVC style) -->
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <div class="auth-container">
        <!-- decorative shape + brand card -->
        <div class="auth-card">
            <div class="brand-header">
                <div class="brand-icon">
                    <i class="fas fa-pen-fancy"></i>
                </div>
                <h1 class="brand-title">NotesManager</h1>
                <p class="brand-tagline">Organize. Capture. Succeed.</p>
            </div>

            <!-- LOGIN FORM 
                 - action points to backend login route (MVC controller)
                 - method POST
                 - no inline scripts, pure HTML/CSS + EJS placeholders for backend errors
                 - 'errorMessage' and 'formData' are passed from your backend (Express controller)
                 - we display server-side validation/error messages using EJS conditional rendering
            -->
            <form action="/login" method="POST" class="login-form" novalidate>
                <!-- Global error message block (for authentication / backend errors) -->
                <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>
                            <%= errorMessage %>
                        </span>
                    </div>
                    <% } %>

                        <!-- Email / Username field -->
                        <div class="input-group">
                            <label for="email" class="input-label">
                                <i class="fas fa-envelope"></i> Email address
                            </label>
                            <div class="input-wrapper">
                                <input type="email" id="email" name="email"
                                    value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
                                    placeholder="you@example.com" autocomplete="email" required>
                                <!-- subtle validation icon (pure css, but backend will handle messages) -->
                            </div>
                            <!-- Optional per-field error can be shown if backend provides field-specific errors -->
                            <% if (typeof fieldErrors !=='undefined' && fieldErrors.email) { %>
                                <div class="field-error"><i class="fas fa-circle-exclamation"></i>
                                    <%= fieldErrors.email %>
                                </div>
                                <% } %>
                        </div>

                        <!-- Password field -->
                        <div class="input-group">
                            <label for="password" class="input-label">
                                <i class="fas fa-lock"></i> Password
                            </label>
                            <div class="input-wrapper">
                                <input type="password" id="password" name="password" placeholder="••••••••"
                                    autocomplete="current-password" required>
                            </div>
                            <% if (typeof fieldErrors !=='undefined' && fieldErrors.password) { %>
                                <div class="field-error"><i class="fas fa-circle-exclamation"></i>
                                    <%= fieldErrors.password %>
                                </div>
                                <% } %>
                        </div>

                        <!-- Extra row: remember me + forgot password (design touch) -->
                        <div class="form-options">
                            <label class="checkbox-label">
                                <input type="checkbox" name="rememberMe" value="true" <%=(typeof formData !=='undefined'
                                    && formData.rememberMe) ? 'checked' : '' %>>
                                <span class="checkmark"></span>
                                <span class="checkbox-text">Remember me</span>
                            </label>
                            <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                        </div>

                        <!-- Submit button -->
                        <button type="submit" class="login-btn">
                            <i class="fas fa-arrow-right-to-bracket"></i> Sign in
                        </button>

                        <!-- Sign up redirect (optional, consistent with notesmanager flow) -->
                        <div class="signup-prompt">
                            <span>Don't have an account?</span>
                            <a href="/register" class="signup-link">Create account</a>
                        </div>
            </form>

            <!-- subtle divider with demo tip (optional) -->
            <div class="info-note">
                <i class="fas fa-shield-alt"></i> Secure login — your notes are protected.
            </div>
        </div>

        <!-- footer / minor design element -->
        <div class="auth-footer">
            <p>© 2025 NotesManager — smarter note-taking</p>
        </div>
    </div>
</body>

</html>